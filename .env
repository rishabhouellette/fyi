# FYIUploader Web Portal configuration
# Copy this file to local `.env` and fill your own credentials.

FYI_PUBLIC_BASE_URL=https://localhost:5050
FYI_WEB_PORTAL_PORT=5050

# YouTube OAuth
YT_CLIENT_ID=YOUR_YOUTUBE_CLIENT_ID
YT_CLIENT_SECRET=YOUR_YOUTUBE_CLIENT_SECRET

# Facebook / Instagram OAuth
FB_APP_ID=YOUR_FACEBOOK_APP_ID
FB_APP_SECRET=YOUR_FACEBOOK_APP_SECRET

# Optional AI service key
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY